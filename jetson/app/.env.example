# ─────────────────────────────────────────────────────────────
# Itinera Terminal — Variables de entorno
# Copia este archivo a .env y completa los valores reales.
# NUNCA commitear .env al repositorio.
# ─────────────────────────────────────────────────────────────

# ── Supabase (requerido) ──────────────────────────────────────
SUPABASE_URL=https://hwsddziticyusncajyes.supabase.co
SUPABASE_ANON_KEY=

# ── Registro del device (solo primera ejecución) ─────────────
# Después de que device.json exista, este valor ya no es necesario.
DEVICE_SETUP_SECRET=
DEVICE_LABEL=jetson-wro-2026

# ── IA (requerido a partir de Sprint 3) ──────────────────────
GROQ_API_KEY=

# ── TTS (opcional — Sprint 4) ────────────────────────────────
ELEVENLABS_API_KEY=

# ── Ubicación del stand WRO ───────────────────────────────────
# Actualizar con las coordenadas reales del venue antes del evento.
WRO_VENUE_LAT=14.0818
WRO_VENUE_LNG=-87.2068

# ── Configuración del servidor ────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOCALE=es

# ── Intervalos de background tasks ───────────────────────────
SYNC_INTERVAL_MIN=60
CONNECTIVITY_CHECK_INTERVAL_SEC=30
EVENT_FLUSH_INTERVAL_SEC=300
